{
  "name": "@devds1989/t-rush-mcp",
  "version": "1.0.7",
  "mcpName": "io.github.DevDs1989/t-rush-mcp",
  "description": "MCP server for t-rush. Exposes TODO/FIXME scanning and streak tracking to AI agents.",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevDs1989/trush-mcp.git"
  },
  "type": "module",
  "bin": {
    "t-rush-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "tsup",
    "bundle:mcpb": "npm install --omit=dev && npx -y @anthropic-ai/mcpb pack . t-rush.mcpb && npm install"
  },
  "keywords": [
    "mcp",
    "todo",
    "productivity",
    "ai"
  ],
  "author": "Devesh",
  "license": "MIT",
  "dependencies": {
    "@devds1989/trush-core": "^1.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  }
}
